  "【FrontMatter】完整学术配置": {
    "scope": "markdown",
    "prefix": "neo:fm-full",
    "body": [
      "---",
      "marp: true",
      "theme: neobeam-lgy",
      "title: ${1:演讲标题}",
      "description: ${2:演讲描述或摘要}",
      "author: ${3:作者名}",
      "date: ${4:2026-03-21}",
      "keywords: ${5:关键词, 多个用逗号分隔}",
      "paginate: true",
      "footer: '${6:页脚文字}'",
      "header: '${7:页眉文字}'",
      "---"
    ],
    "description": "学术/正式演讲的完整 Front-matter"
  },

  "【FrontMatter】教学课件": {
