  "【FrontMatter】基础 Marp 演示": {
    "scope": "markdown",
    "prefix": "neo:fm-basic",
    "body": [
      "---",
      "marp: true",
      "theme: neobeam-lgy",
      "---"
    ],
    "description": "最小化 Front-matter（基础配置）"
